Package: free1way
Title: Additional Documentation and Regression Tests for stats::free1way
Date: 2026-02-25
Version: 0.6-0
Authors@R: c(person(given = "Torsten", family = "Hothorn", role = c("aut", "cre"),
                    email = "Torsten.Hothorn@R-project.org"),
             person(given = "Kurt", family = "Hornik", role = "aut",
